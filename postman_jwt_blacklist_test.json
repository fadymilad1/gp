{
	"info": {
		"_postman_id": "942b58d9-4824-4fbb-a128-d7b172a170bb",
		"name": "Medify JWT Blacklist & Rotation Test",
		"description": "Automated tests to verify that JWT tokens are correctly blacklisted upon logout and cannot be reused to refresh access tokens.",
		"schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
	},
	"item": [
		{
			"name": "1. Signup User",
			"event": [
				{
					"listen": "prerequest",
					"script": {
						"exec": [
							"const uniqueId = Date.now();",
							"pm.collectionVariables.set(\"test_email\", `jwt_user_${uniqueId}@example.com`);"
						],
						"type": "text/javascript"
					}
				}
			],
			"request": {
				"method": "POST",
				"header": [
					{
						"key": "Content-Type",
						"value": "application/json"
					}
				],
				"body": {
					"mode": "raw",
					"raw": "{\n    \"email\": \"{{test_email}}\",\n    \"password\": \"JWTSecurePass123\",\n    \"password_confirm\": \"JWTSecurePass123\",\n    \"name\": \"JWT Test User\",\n    \"business_type\": \"hospital\"\n}"
				},
				"url": {
					"raw": "{{base_url}}/api/auth/signup/",
					"host": [
						"{{base_url}}"
					],
					"path": [
						"api",
						"auth",
						"signup",
						""
					]
				}
			},
			"response": []
		},
		{
			"name": "2. Login (Get Refresh & Access Tokens)",
			"event": [
				{
					"listen": "test",
					"script": {
						"exec": [
							"const responseJson = pm.response.json();",
							"if (responseJson.tokens) {",
							"    pm.collectionVariables.set(\"access_token\", responseJson.tokens.access);",
							"    pm.collectionVariables.set(\"refresh_token\", responseJson.tokens.refresh);",
							"    console.log(\"Saved tokens successfully!\");",
							"}"
						],
						"type": "text/javascript"
					}
				}
			],
			"request": {
				"method": "POST",
				"header": [
					{
						"key": "Content-Type",
						"value": "application/json"
					}
				],
				"body": {
					"mode": "raw",
					"raw": "{\n    \"email\": \"{{test_email}}\",\n    \"password\": \"JWTSecurePass123\"\n}"
				},
				"url": {
					"raw": "{{base_url}}/api/auth/login/",
					"host": [
						"{{base_url}}"
					],
					"path": [
						"api",
						"auth",
						"login",
						""
					]
				}
			},
			"response": []
		},
		{
			"name": "3. Verify Refresh Token Works Initially",
			"event": [
				{
					"listen": "test",
					"script": {
						"exec": [
							"pm.test(\"Status code is 200 OK (Token works initially)\", function () {",
							"    pm.response.to.have.status(200);",
							"});",
							"const responseJson = pm.response.json();",
							"if (responseJson.access) {",
							"    pm.collectionVariables.set(\"access_token\", responseJson.access);",
							"}",
							"if (responseJson.refresh) {",
							"    pm.collectionVariables.set(\"refresh_token\", responseJson.refresh);",
							"    console.log(\"Rotated Refresh Token saved successfully!\");",
							"}"
						],
						"type": "text/javascript"
					}
				}
			],
			"request": {
				"method": "POST",
				"header": [
					{
						"key": "Content-Type",
						"value": "application/json"
					}
				],
				"body": {
					"mode": "raw",
					"raw": "{\n    \"refresh\": \"{{refresh_token}}\"\n}"
				},
				"url": {
					"raw": "{{base_url}}/api/auth/refresh/",
					"host": [
						"{{base_url}}"
					],
					"path": [
						"api",
						"auth",
						"refresh",
						""
					]
				}
			},
			"response": []
		},
		{
			"name": "4. Logout (Blacklist Refresh Token)",
			"event": [
				{
					"listen": "test",
					"script": {
						"exec": [
							"pm.test(\"Logged out successfully (Status 200)\", function () {",
							"    pm.response.to.have.status(200);",
							"});"
						],
						"type": "text/javascript"
					}
				}
			],
			"request": {
				"method": "POST",
				"header": [
					{
						"key": "Content-Type",
						"value": "application/json"
					},
					{
						"key": "Authorization",
						"value": "Bearer {{access_token}}"
					}
				],
				"body": {
					"mode": "raw",
					"raw": "{\n    \"refresh\": \"{{refresh_token}}\"\n}"
				},
				"url": {
					"raw": "{{base_url}}/api/auth/logout/",
					"host": [
						"{{base_url}}"
					],
					"path": [
						"api",
						"auth",
						"logout",
						""
					]
				}
			},
			"response": []
		},
		{
			"name": "5. Try to Refresh Again (Should Fail 401 - Blacklisted)",
			"event": [
				{
					"listen": "test",
					"script": {
						"exec": [
							"pm.test(\"Status code is 401 Unauthorized (Blacklist Works!)\", function () {",
							"    pm.response.to.have.status(401);",
							"});"
						],
						"type": "text/javascript"
					}
				}
			],
			"request": {
				"method": "POST",
				"header": [
					{
						"key": "Content-Type",
						"value": "application/json"
					}
				],
				"body": {
					"mode": "raw",
					"raw": "{\n    \"refresh\": \"{{refresh_token}}\"\n}"
				},
				"url": {
					"raw": "{{base_url}}/api/auth/refresh/",
					"host": [
						"{{base_url}}"
					],
					"path": [
						"api",
						"auth",
						"refresh",
						""
					]
				}
			},
			"response": []
		}
	],
	"variable": [
		{
			"key": "base_url",
			"value": "http://127.0.0.1:8000"
		},
		{
			"key": "access_token",
			"value": ""
		},
		{
			"key": "refresh_token",
			"value": ""
		},
		{
			"key": "test_email",
			"value": ""
		}
	]
}
