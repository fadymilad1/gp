SECRET_KEY=django-insecure-change-this-in-production
DEBUG=True
DB_ENGINE=sqlite

# Database settings (PostgreSQL - for production)
# DB_ENGINE=postgresql
# DB_NAME=medify_db
# DB_USER=postgres
# DB_PASSWORD=your-password
# DB_HOST=localhost
# DB_PORT=5432

# Frontend URL (for CORS)
FRONTEND_URL=http://localhost:3000

# Hugging Face medical chatbot
HF_MEDICAL_MODEL_ID=microsoft/Phi-3-mini-4k-instruct
HUGGINGFACE_API_TOKEN=hf_your_real_token_here
# Optional override, normally derived from HF_MEDICAL_MODEL_ID
# HUGGINGFACE_API_URL=https://router.huggingface.co/v1/chat/completions
CHATBOT_HTTP_TIMEOUT=60
CHATBOT_STREAM_CHUNK_SIZE=28

# Gemini API key for RAG service
GEMINI_API_KEY=your_gemini_api_key_here

# Google Sheets write access (bidirectional sync with pharmacy products)
# Create a service account in Google Cloud, enable Google Sheets API, then either:
# - set GOOGLE_SERVICE_ACCOUNT_FILE to the JSON key path, or
# - paste the JSON into GOOGLE_SERVICE_ACCOUNT_JSON (single line)
# Share each pharmacy Google Sheet with the service account email as Editor.
GOOGLE_SERVICE_ACCOUNT_FILE=
GOOGLE_SERVICE_ACCOUNT_JSON=
