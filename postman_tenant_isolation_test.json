		{
			"name": "7. Tenant B Tries to GET Tenant A's Doctor (Should Fail 404)",
			"event": [
				{
					"listen": "test",
					"script": {
						"exec": [
							"pm.test(\"Status code is 404 Not Found (Data Isolation Works!)\", function () {",
							"    pm.response.to.have.status(404);",
							"});"
						],
						"type": "text/javascript"
					}
				}
			],
			"request": {
				"method": "GET",
				"header": [
					{
						"key": "Authorization",
						"value": "Bearer {{tenant_b_token}}"
					}
				],
				"url": {
					"raw": "{{base_url}}/api/hospital/admin/doctors/{{tenant_a_doctor_id}}/",
					"host": [
						"{{base_url}}"
					],
					"path": [
						"api",
						"hospital",
						"admin",
						"doctors",
						"{{tenant_a_doctor_id}}",
						""
					]
				}
			},
			"response": []
		},
