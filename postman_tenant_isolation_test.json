{
	"info": {
		"_postman_id": "845c43d9-9524-4fbb-a128-d7b172a170bb",
		"name": "Medify Multi-Tenant Isolation Test",
		"description": "Automated requests to verify that Tenant B cannot access or modify resources belonging to Tenant A.",
		"schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
	},
	"item": [
		{
			"name": "1. Signup Tenant A",
			"event": [
				{
					"listen": "prerequest",
					"script": {
						"exec": [
							"const uniqueId = Date.now();",
							"pm.collectionVariables.set(\"tenant_a_email\", `tenanta_${uniqueId}@example.com`);",
							"pm.collectionVariables.set(\"tenant_a_username\", `tenanta_${uniqueId}`);",
							"pm.collectionVariables.set(\"tenant_a_subdomain\", `tenanta-hospital-${uniqueId}`);"
						],
						"type": "text/javascript"
					}
				}
			],
			"request": {
				"method": "POST",
				"header": [
					{
						"key": "Content-Type",
						"value": "application/json"
					}
				],
				"body": {
					"mode": "raw",
					"raw": "{\n    \"email\": \"{{tenant_a_email}}\",\n    \"password\": \"TenantAPass123\",\n    \"password_confirm\": \"TenantAPass123\",\n    \"name\": \"Tenant A Admin\",\n    \"business_type\": \"hospital\"\n}"
				},
				"url": {
					"raw": "{{base_url}}/api/auth/signup/",
					"host": [
						"{{base_url}}"
					],
					"path": [
						"api",
						"auth",
						"signup",
						""
					]
				}
			},
			"response": []
		},
		{
			"name": "2. Login Tenant A",
			"event": [
				{
					"listen": "test",
					"script": {
						"exec": [
							"const responseJson = pm.response.json();",
							"const token = (responseJson.tokens && responseJson.tokens.access) || responseJson.access;",
							"if (token) {",
							"    pm.collectionVariables.set(\"tenant_a_token\", token);",
							"    console.log(\"Saved Tenant A Token!\");",
							"}"
						],
						"type": "text/javascript"
					}
				}
			],
			"request": {
				"method": "POST",
				"header": [
					{
						"key": "Content-Type",
						"value": "application/json"
					}
				],
				"body": {
